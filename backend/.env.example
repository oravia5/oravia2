PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/oravia
JWT_SECRET=your_jwt_production_secret_key
JWT_EXPIRES_IN=7d
UPLOAD_DIR=./uploads

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=your_s3_bucket_name

# Ably Key (For Real-time chat messaging)
ABLY_API_KEY=your_ably_api_key

# SMTP Configuration
SMTP_SERVICE=gmail
SMTP_USER=your_smtp_email@gmail.com
SMTP_PASS=your_smtp_app_password
SMTP_FROM="Oravia Admin" <your_smtp_email@gmail.com>
